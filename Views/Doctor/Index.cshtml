            <div class="ai-text">
              <strong>Account Created</strong>
              <span>12 Jan 2026, 10:30 AM</span>
            </div>
            <svg class="chevron-right" viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </div>
          <div class="account-info-item">
            <div class="ai-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></div>
            <div class="ai-text">
              <strong>Last Login</strong>
              <span>16 Jul 2026, 09:15 AM</span>
            </div>
            <svg class="chevron-right" viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </div>
        </div>
      </div>
