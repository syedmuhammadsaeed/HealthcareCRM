@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Doctor Dashboard — HealthcareCRM</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FAF7F1;
    --forest:#1B4332;
    --forest-dark:#122E22;
    --sage:#6E9C7D;
    --sage-light:#E4EFE3;
    --coral:#E76F51;
    --coral-light:#FBE3DC;
    --amber:#B3672B;
    --amber-light:#FBEADB;
    --ink:#26301F;
    --muted:#7C8873;
    --line:#E7E0D2;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter',sans-serif;
    background:var(--cream);
    color:var(--ink);
    min-height:100vh;
    padding-bottom:60px;
  }

  /* ---------- Top bar ---------- */
  .top-row{ position:relative; display:flex; justify-content:center; align-items:center; padding:22px 28px 10px; }
  .navbar{
    display:flex; align-items:center; gap:6px;
    background:var(--forest-dark); border-radius:999px; padding:8px 10px 8px 8px;
    box-shadow:0 20px 40px -16px rgba(18,46,34,.45), 0 2px 0 rgba(255,255,255,.04) inset;
  }
  .nav-mark{
    width:40px; height:40px; border-radius:50%; background:var(--sage);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    font-family:'Fraunces',serif; font-weight:700; font-size:17px; color:var(--forest-dark);
  }
  .nav-links{ display:flex; align-items:center; gap:4px; padding:0 6px; }
  .nav-links a{
    text-decoration:none; color:#DCE6DE; font-size:14px; font-weight:600;
    padding:10px 16px; border-radius:999px; transition:color .15s ease, background .15s ease; white-space:nowrap;
  }
  .nav-links a:hover{ color:#fff; background:rgba(255,255,255,.06); }
  .nav-links a.active{ color:var(--forest-dark); background:#fff; }
  .nav-links a:focus-visible{ outline:2px solid var(--coral); outline-offset:2px; }
  .nav-user{
    display:flex; align-items:center; gap:9px; background:#fff; color:var(--ink);
    border-radius:999px; padding:8px 16px 8px 8px; font-size:13.5px; font-weight:600; cursor:pointer; border:none;
  }
  .nav-user .avatar{
    width:26px; height:26px; border-radius:50%; background:var(--coral); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; flex-shrink:0;
  }
  .btn-logout{
    position:absolute; right:28px; top:22px;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;
    background:#fff; border:1px solid var(--line); border-radius:14px;
    padding:9px 18px; font-size:12px; font-weight:700; color:var(--forest); cursor:pointer;
    transition:border-color .15s ease, background .15s ease, color .15s ease;
  }
  .btn-logout .ic{ font-size:15px; line-height:1; color:var(--forest); }
  .btn-logout:hover{ border-color:var(--coral); background:#FFF8F6; color:var(--coral); }
  .btn-logout:hover .ic{ color:var(--coral); }
  @@media (max-width:900px){
    .nav-links a{ padding:9px 11px; font-size:13px; }
    .nav-user span.label{ display:none; }
    .btn-logout{ position:static; margin:12px auto 0; }
    .top-row{ flex-direction:column; }
  }

  /* ---------- Page shell ---------- */
  .page{ max-width:1080px; margin:0 auto; padding:26px 28px 0; }

  .page-head{ display:flex; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:24px; flex-wrap:wrap; }
  .page-head h1{
    font-family:'Fraunces',serif; font-style:italic; font-weight:500; font-size:30px; margin:0 0 6px; color:var(--forest);
  }
  .page-head p{ margin:0; color:var(--muted); font-size:13.5px; }
  .btn-ghost{
    background:#fff; border:1px solid var(--line); color:var(--forest); border-radius:10px;
    padding:10px 16px; font-size:13.5px; font-weight:700; cursor:pointer;
  }
  .btn-ghost:hover{ border-color:var(--sage); }

  /* ---------- Stat cards ---------- */
  .stat-row{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; }
  @@media (max-width:900px){ .stat-row{ grid-template-columns:repeat(2,1fr); } }
  .stat{
    background:#fff; border:1px solid var(--line); border-radius:16px; padding:18px 20px;
    display:flex; flex-direction:column; gap:10px;
  }
  .stat .top-row{ display:flex; justify-content:space-between; align-items:center; }
  .stat .icon{
    width:36px; height:36px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:16px;
  }
  .stat.c1 .icon{ background:var(--sage-light); color:var(--forest); }
  .stat.c2 .icon{ background:#E6ECF7; color:#3B5CA8; }
  .stat.c3 .icon{ background:var(--amber-light); color:var(--amber); }
  .stat.c4 .icon{ background:var(--coral-light); color:var(--coral); }
  .stat .num{ font-family:'Fraunces',serif; font-size:30px; font-weight:600; line-height:1; }
  .stat .lbl{ font-size:12.5px; color:var(--muted); }
  .stat .sub{ font-size:11px; color:var(--muted); }

  /* ---------- Panel ---------- */
  .panel{ background:#fff; border:1px solid var(--line); border-radius:16px; overflow:hidden; }
  .panel-head{
    display:flex; justify-content:space-between; align-items:center; gap:14px; flex-wrap:wrap;
    padding:18px 20px; border-bottom:1px solid var(--line);
  }
  .panel-head h3{ margin:0; font-size:16px; font-weight:700; font-family:'Fraunces',serif; }
  .panel-head .date-pill{
    font-size:12px; font-weight:700; color:var(--forest); background:var(--sage-light);
    padding:6px 12px; border-radius:999px; font-family:'IBM Plex Mono',monospace;
  }

  .appt-list{ display:flex; flex-direction:column; }
  .appt-item{
    display:grid; grid-template-columns:70px 3px 1fr auto; align-items:center; gap:14px;
    padding:14px 20px; border-bottom:1px solid var(--line);
  }
  .appt-item:last-child{ border-bottom:none; }
  .appt-item:hover{ background:#FDFBF6; }
  .appt-time{ font-family:'IBM Plex Mono',monospace; font-size:12.5px; color:var(--muted); }
  .appt-bar{ width:3px; height:34px; border-radius:3px; }
  .appt-bar.done{ background:var(--sage); }
  .appt-bar.next{ background:var(--amber); }
  .appt-bar.wait{ background:var(--line); }
  .appt-info .name{ font-size:14px; font-weight:600; }
  .appt-info .type{ font-size:12px; color:var(--muted); margin-top:2px; }
  .appt-status{
    font-size:11px; font-weight:700; padding:5px 12px; border-radius:999px; white-space:nowrap;
  }
  .appt-status.done{ background:var(--sage-light); color:var(--forest); }
  .appt-status.next{ background:var(--amber-light); color:var(--amber); }
  .appt-status.wait{ background:#F1ECE1; color:var(--muted); }

  .panel-footer{ padding:14px 20px; text-align:center; }
  .see-all{ font-size:12.5px; font-weight:700; color:var(--forest); text-decoration:none; }
  .see-all:hover{ color:var(--coral); }
</style>
</head>
<body>

  <div class="top-row">
    <nav class="navbar" aria-label="Primary">
      <div class="nav-mark" aria-hidden="true">+</div>
      <div class="nav-links">
        <a href="#" class="active">Overview</a>
        <a href="#">Patients</a>
        <a href="#">Appointments</a>
        <a href="#">Reports</a>
        <a href="/SuperAdmin" id="nav-approvals" style="display:none;">Approvals</a>
      </div>
      <button class="nav-user">
        <span class="avatar">DR</span>
        <span class="label">Doctor Dashboard</span>
      </button>
    </nav>
    <button class="btn-logout" onclick="logout()"><span class="ic">⏻</span>Logout</button>
  </div>

  <div class="page">

    <div class="page-head">
      <div>
        <h1>Good morning, Doctor</h1>
        <p>Here's your day at a glance</p>
      </div>
      <button class="btn-ghost">View full schedule</button>
    </div>

    <div class="stat-row">
      <div class="stat c1">
        <div class="top-row"><span class="icon">📅</span></div>
        <div class="num">8</div>
        <div class="lbl">Appointments today</div>
        <div class="sub">3 completed · 5 remaining</div>
      </div>
      <div class="stat c2">
        <div class="top-row"><span class="icon">🧑🤝🧑</span></div>
        <div class="num">142</div>
        <div class="lbl">Total patients</div>
        <div class="sub">Under your care</div>
      </div>
      <div class="stat c3">
        <div class="top-row"><span class="icon">⏱</span></div>
        <div class="num">11:15</div>
        <div class="lbl">Next appointment</div>
        <div class="sub">Ayesha Khan · Follow-up</div>
      </div>
      <div class="stat c4">
        <div class="top-row"><span class="icon">⚠</span></div>
        <div class="num">2</div>
        <div class="lbl">Critical patients</div>
        <div class="sub">Need review today</div>
      </div>
    </div>

    <div class="panel" style="margin-bottom:24px;">
      <div class="panel-head" style="border-bottom:none; padding-bottom:0;">
        <h3 style="font-size:16px;">Consultation Fee Settings</h3>
      </div>
      <div style="padding:16px 24px 24px;">
        <form id="fee-form" style="display:flex; gap:16px; align-items:flex-end;">
            <div style="flex:1; max-width:200px;">
                <label style="display:block; font-size:12px; color:var(--muted); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">Fee Amount</label>
                <input type="number" id="fee-amount" required min="0" step="0.01" style="width:100%; padding:10px; border:1px solid var(--line); border-radius:8px; outline:none; transition:border-color 0.2s; font-family:inherit;">
            </div>
            <div style="flex:1; max-width:140px;">
                <label style="display:block; font-size:12px; color:var(--muted); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">Currency</label>
                <select id="fee-currency" required style="width:100%; padding:10px; border:1px solid var(--line); border-radius:8px; outline:none; font-family:inherit;">
                    <option value="Rs">Rs (PKR)</option>
                    <option value="$">$ (USD)</option>
                    <option value="€">€ (EUR)</option>
                    <option value="£">£ (GBP)</option>
                    <option value="A$">A$ (AUD)</option>
                    <option value="C$">C$ (CAD)</option>
                    <option value="₹">₹ (INR)</option>
                    <option value="¥">¥ (JPY)</option>
                    <option value="CHF">CHF</option>
                    <option value="NZ$">NZ$ (NZD)</option>
                    <option value="S$">S$ (SGD)</option>
                    <option value="HK$">HK$ (HKD)</option>
                </select>
            </div>
            <button type="submit" class="btn-primary" id="btn-update-fee" style="padding:11px 20px; font-size:13.5px; border-radius:8px; font-weight:600; background:var(--forest); color:#fff; border:none; cursor:pointer;">Update Fee</button>
            <span id="fee-alert" style="font-size:13px; font-weight:500; display:none; padding:10px 16px; border-radius:6px; margin-left:12px;"></span>
        </form>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <h3>Today's appointments</h3>
        <span class="date-pill">Today</span>
      </div>
      <div class="appt-list" id="doctor-appointments-list">
        <div style="padding:40px; text-align:center; color:var(--muted);">Loading your patients...</div>
      </div>
      <div class="panel-footer">
        <a class="see-all" href="#">View full appointment calendar →</a>
      </div>
    </div>

  </div>
  <script>
    function logout() {
      localStorage.removeItem('hcrm_token');
      document.cookie = 'hcrm_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
      window.location.replace('/Account/Login');
    }

    // Parse JWT to get role
    function parseJwt(token) {
        try {
            var base64Url = token.split('.')[1];
            var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
            var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
            }).join(''));
            return JSON.parse(jsonPayload);
        } catch (e) {
            return null;
        }
    }

    document.addEventListener('DOMContentLoaded', async function () {
        var token = localStorage.getItem('hcrm_token');
        if (!token) {
            window.location.replace('/Account/Login');
            return;
        }

        var payload = parseJwt(token);
        if (payload) {
            var role = payload.role || payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role'];
            if (role === 'SuperAdmin') {
                var navApprovals = document.getElementById('nav-approvals');
                if (navApprovals) {
                    navApprovals.style.display = 'inline-block';
                }
            }
            if (payload.name) {
                var nameEl = document.querySelector('.nav-user .label');
                var avatarEl = document.querySelector('.nav-user .avatar');
                if (nameEl) nameEl.textContent = 'Dr. ' + payload.name;
                if (avatarEl) avatarEl.textContent = payload.name.substring(0, 2).toUpperCase();
            }
        }

        try {
            var payload = parseJwt(token);
            var myId = payload['sub'] || payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'];
            
            var [patResp, docResp] = await Promise.all([
                fetch('/api/patients', { headers: { 'Authorization': 'Bearer ' + token } }),
                fetch('/api/doctors', { headers: { 'Authorization': 'Bearer ' + token } })
            ]);
            var body = await patResp.json();
            var docBody = await docResp.json();
            
            if (docBody.success && docBody.data && myId) {
                var me = docBody.data.find(d => d.id === myId);
                if (me) {
                    if (me.fee != null) document.getElementById('fee-amount').value = me.fee;
                    if (me.currency) document.getElementById('fee-currency').value = me.currency;
                }
            }
            
            document.getElementById('fee-form').onsubmit = async function(e) {
                e.preventDefault();
                var btn = document.getElementById('btn-update-fee');
                var alertBox = document.getElementById('fee-alert');
                btn.disabled = true;
                btn.textContent = 'Updating...';
                
                try {
                    var updateResp = await fetch('/api/doctors/fee', {
                        method: 'POST',
                        headers: { 
                            'Authorization': 'Bearer ' + token,
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            fee: parseFloat(document.getElementById('fee-amount').value),
                            currency: document.getElementById('fee-currency').value
                        })
                    });
                    var updateBody = await updateResp.json();
                    if (updateBody.success) {
                        alertBox.textContent = 'Fee updated successfully!';
                        alertBox.style.color = 'var(--forest-dark)';
                        alertBox.style.background = 'var(--sage-light)';
                    } else {
                        alertBox.textContent = updateBody.message || 'Failed to update fee.';
                        alertBox.style.color = 'var(--error)';
                        alertBox.style.background = 'var(--coral-light)';
                    }
                    alertBox.style.display = 'inline-block';
                    setTimeout(() => { alertBox.style.display = 'none'; }, 3000);
                } catch(err) {
                    alertBox.textContent = 'Network error.';
                    alertBox.style.color = 'var(--error)';
                    alertBox.style.background = 'var(--coral-light)';
                    alertBox.style.display = 'inline-block';
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Update Fee';
                }
            };
            
            var listEl = document.getElementById('doctor-appointments-list');
            
            if (body.success && body.data && body.data.items) {
                var patients = body.data.items;
                
                // Sort by appointment datetime
                patients.forEach(function(p) {
                    p._dateObj = new Date(0);
                    if (p.appointmentDate) {
                        var d = new Date(p.appointmentDate);
                        if (p.appointmentTime) {
                            var parts = p.appointmentTime.split(':');
                            if (parts.length >= 2) {
                                d.setHours(parseInt(parts[0], 10));
                                d.setMinutes(parseInt(parts[1], 10));
                            }
                        }
                        p._dateObj = d;
                    }
                });
                
                patients.sort(function(a, b) {
                    return a._dateObj - b._dateObj;
                });
                
                if (patients.length === 0) {
                    listEl.innerHTML = '<div style="padding:40px; text-align:center; color:var(--muted);">No patients assigned to you yet.</div>';
                } else {
                    var html = '';
                    var now = new Date();
                    
                    // Track which one is next
                    var nextApptIndex = patients.findIndex(p => p.appointmentStatus !== 'Completed');
                    
                    patients.forEach(function(p, i) {
                        var isNext = i === nextApptIndex;
                        var time = p.appointmentTime || '--:--';
                        var date = p.appointmentDate ? new Date(p.appointmentDate).toLocaleDateString() : 'No date';
                        var isTimeStarted = now >= p._dateObj;
                        
                        var isCompleted = p.appointmentStatus === 'Completed';
                        var statusHtml = '';
                        if (isCompleted) {
                            statusHtml = '<span class="appt-status" style="background:var(--sage-light); color:var(--forest);">Done ✓</span>';
                        } else if (isTimeStarted) {
                            statusHtml = `<button class="btn-primary" onclick="completeAppointment('${p.id}')" style="padding:6px 12px; font-size:12px; border-radius:6px; background:var(--forest); color:#fff; border:none; cursor:pointer;">Mark Done</button>`;
                        } else {
                            statusHtml = `<button class="btn-primary" disabled style="padding:6px 12px; font-size:12px; border-radius:6px; background:var(--muted); color:#fff; border:none; cursor:not-allowed; opacity:0.6;">Scheduled</button>`;
                        }
                        
                        html += `
                        <div class="appt-item">
                          <span class="appt-time">${time}</span>
                          <span class="appt-bar ${isNext ? 'next' : 'wait'}"></span>
                          <div class="appt-info"><div class="name">${p.name}</div><div class="type">${date}</div></div>
                          ${statusHtml}
                        </div>
                        `;
                    });
                    listEl.innerHTML = html;
                    
                    // Update stats
                    document.querySelector('.stat.c1 .num').textContent = patients.length;
                    document.querySelector('.stat.c1 .sub').textContent = 'Assigned to you';
                    document.querySelector('.stat.c2 .num').textContent = patients.length;
                    
                    if (nextApptIndex !== -1) {
                        document.querySelector('.stat.c3 .num').textContent = patients[nextApptIndex].appointmentTime || '--:--';
                        document.querySelector('.stat.c3 .sub').textContent = patients[nextApptIndex].name;
                    } else {
                        document.querySelector('.stat.c3 .num').textContent = '--:--';
                        document.querySelector('.stat.c3 .sub').textContent = 'None';
                    }
                }
            } else {
                listEl.innerHTML = '<div style="padding:40px; text-align:center; color:var(--coral);">Failed to load patients.</div>';
            }
        } catch (e) {
            document.getElementById('doctor-appointments-list').innerHTML = '<div style="padding:40px; text-align:center; color:var(--coral);">Network error.</div>';
        }
    });

    window.completeAppointment = async function(id) {
        if (!confirm('Mark this appointment as completed?')) return;
        try {
            var token = localStorage.getItem('jwt');
            var resp = await fetch('/api/patients/' + id + '/complete', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            var body = await resp.json();
            if (body.success) {
                window.location.reload();
            } else {
                alert(body.message || 'Failed to complete appointment.');
            }
        } catch(e) {
            alert('Network error.');
        }
    }
  </script>
</body>
</html>
