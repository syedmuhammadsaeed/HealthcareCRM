        <div class="password-form">
          <div class="input-group full-width">
            <label class="form-label">Current Password</label>
            <div class="input-with-icon">
              <input type="password" id="pwd-current" class="input-control" placeholder="Enter current password">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" onclick="togglePwd('pwd-current', this)"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
