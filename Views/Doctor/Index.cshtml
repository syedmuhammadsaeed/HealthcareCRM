  </main>
</div>

<script>
    var _profilePicBase64 = '';

    function toggleSidebar() {
        document.querySelector('.sidebar').classList.toggle('collapsed');
    }

    function togglePwd(id, svg) {
        var input = document.getElementById(id);
        if (input.type === 'password') {
            input.type = 'text';
            svg.style.color = 'var(--forest)';
        } else {
            input.type = 'password';
            svg.style.color = 'var(--muted)';
        }
    }

    function checkPwdRules(val) {
        document.getElementById('rule-len').style.fontWeight = val.length >= 8 ? '700' : 'normal';
        document.getElementById('rule-num').style.fontWeight = /\d/.test(val) ? '700' : 'normal';
        document.getElementById('rule-up').style.fontWeight = /[A-Z]/.test(val) ? '700' : 'normal';
        document.getElementById('rule-sp').style.fontWeight = /[^A-Za-z0-9]/.test(val) ? '700' : 'normal';
    }

    function updatePassword() {
        var err = document.getElementById('pwd-error');
        var cur = document.getElementById('pwd-current').value;
        var neu = document.getElementById('pwd-new').value;
        var con = document.getElementById('pwd-confirm').value;
        if (!cur || !neu || !con) {
            err.textContent = 'All password fields are required.';
            err.style.color = 'var(--coral)';
            err.style.display = 'inline-block';
        } else if (neu !== con) {
            err.textContent = 'New passwords do not match.';
            err.style.color = 'var(--coral)';
            err.style.display = 'inline-block';
        } else {
            err.textContent = 'Password updated successfully!';
            err.style.color = 'var(--forest)';
            err.style.display = 'inline-block';
            setTimeout(() => { err.style.display = 'none'; document.getElementById('pwd-current').value=''; document.getElementById('pwd-new').value=''; document.getElementById('pwd-confirm').value=''; checkPwdRules(''); }, 3000);
        }
    }

    async function saveProfile() {
        var err = document.getElementById('prof-error');
        var btn = event.target;
        var name = document.getElementById('prof-name').value;
        var email = document.getElementById('prof-email').value;
        var phone = document.getElementById('prof-phone').value;
        var spec = document.getElementById('prof-spec').value;
        var qual = document.getElementById('prof-qual').value;
        
        if (!name.trim() || !email.trim() || !phone.trim() || !spec.trim() || !qual.trim()) {
            err.textContent = 'Please fill in all required fields.';
            err.style.color = 'var(--coral)';
            err.style.display = 'inline-block';
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
            var token = localStorage.getItem('hcrm_token');
            var resp = await fetch('/api/doctors/profile', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: name,
                    email: email,
                    phone: phone,
                    specialization: spec,
                    qualification: qual,
                    profilePictureBase64: _profilePicBase64
                })
            });

            var body = await resp.json();
            if (body.success) {
                err.textContent = 'Profile updated successfully!';
                err.style.color = 'var(--forest)';
                err.style.display = 'inline-block';
                setTimeout(() => { err.style.display = 'none'; }, 3000);
                
                document.getElementById('nav-name').textContent = 'Dr. ' + name;
                if (_profilePicBase64) {
                    var nv = document.getElementById('nav-avatar');
                    nv.textContent = '';
                    nv.style.backgroundImage = 'url(' + _profilePicBase64 + ')';
                    nv.style.backgroundSize = 'cover';
                    nv.style.backgroundPosition = 'center';
                }
            } else {
                err.textContent = body.message || 'Failed to update profile.';
                err.style.color = 'var(--coral)';
                err.style.display = 'inline-block';
            }
        } catch(e) {
            err.textContent = 'Network error.';
            err.style.color = 'var(--coral)';
            err.style.display = 'inline-block';
        } finally {
            btn.disabled = false;
            btn.textContent = 'Save Changes';
        }
    }

    function previewProfilePic(e) {
        var file = e.target.files[0];
        if(file) {
            var reader = new FileReader();
            reader.onload = function(ev) {
                _profilePicBase64 = ev.target.result;
                var pv = document.getElementById('prof-avatar-preview');
                pv.textContent = '';
                pv.style.backgroundImage = 'url(' + ev.target.result + ')';
                pv.style.backgroundSize = 'cover';
                pv.style.backgroundPosition = 'center';
            };
            reader.readAsDataURL(file);
        }
    }

    function switchSettingsTab(tab) {
        if(tab === 'profile') {
            document.getElementById('tab-profile').classList.add('active');
            document.getElementById('tab-security').classList.remove('active');
            document.getElementById('settings-profile-panel').style.display = 'block';
            document.getElementById('settings-password-panel').style.display = 'none';
            document.getElementById('settings-account-panel').style.display = 'none';
        } else {
            document.getElementById('tab-security').classList.add('active');
            document.getElementById('tab-profile').classList.remove('active');
            document.getElementById('settings-profile-panel').style.display = 'none';
            document.getElementById('settings-password-panel').style.display = 'block';
            document.getElementById('settings-account-panel').style.display = 'block';
        }
    }

    function toggleLogout() {
        var btn = document.getElementById('logout-btn');
        if (btn.style.display === 'none' || btn.style.display === '') {
            btn.style.display = 'flex';
        } else {
            btn.style.display = 'none';
        }
    }

    function logout() {
      localStorage.removeItem('hcrm_token');
      document.cookie = 'hcrm_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
      window.location.replace('/Account/Login');
    }

    function parseJwt(token) {
        try {
            var base64Url = token.split('.')[1];
            var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
            var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
            }).join(''));
            return JSON.parse(jsonPayload);
        } catch (e) {
            return null;
        }
    }

    document.addEventListener('DOMContentLoaded', async function () {
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', function(e) {
                var targetId = this.getAttribute('data-target');
                if (targetId) {
                    e.preventDefault();
                    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                    this.classList.add('active');

                    document.getElementById('dashboard-section').style.display = 'none';
                    document.getElementById('fee-section').style.display = 'none';
                    document.getElementById('patients-section').style.display = 'none';
                    document.getElementById('settings-section').style.display = 'none';

                    document.getElementById(targetId).style.display = 'block';
                }
            });
        });

        var token = localStorage.getItem('hcrm_token');
        if (!token) {
            window.location.replace('/Account/Login');
            return;
        }

        var payload = parseJwt(token);
        if (payload) {
            if (payload.name) {
                var nameEl = document.getElementById('nav-name');
                var avatarEl = document.getElementById('nav-avatar');
                if (nameEl) nameEl.textContent = 'Dr. ' + payload.name;
                if (avatarEl) avatarEl.textContent = payload.name.substring(0, 2).toUpperCase();
            }
        }

        try {
            var payloadObj = parseJwt(token);
            var myId = payloadObj['sub'] || payloadObj['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'];
            
            var [patResp, docResp] = await Promise.all([
                fetch('/api/patients', { headers: { 'Authorization': 'Bearer ' + token } }),
                fetch('/api/doctors', { headers: { 'Authorization': 'Bearer ' + token } })
            ]);
            var body = await patResp.json();
            var docBody = await docResp.json();
            
            if (docBody.success && docBody.data && myId) {
                var me = docBody.data.find(d => d.id === myId);
                if (me) {
                    if (me.fee != null) document.getElementById('fee-amount').value = me.fee;
                    if (me.currency) document.getElementById('fee-currency').value = me.currency;

                    if (me.name) {
                        document.getElementById('prof-name').value = me.name;
                    }
                    if (me.email) document.getElementById('prof-email').value = me.email;
                    if (me.phone) document.getElementById('prof-phone').value = me.phone;
                    if (me.specialization) document.getElementById('prof-spec').value = me.specialization;
                    if (me.qualification) document.getElementById('prof-qual').value = me.qualification;
                    if (me.profilePictureUrl) {
                        var pv = document.getElementById('prof-avatar-preview');
                        pv.textContent = '';
                        pv.style.backgroundImage = 'url(' + me.profilePictureUrl + ')';
                        pv.style.backgroundSize = 'cover';
                        pv.style.backgroundPosition = 'center';
                        
                        var nv = document.getElementById('nav-avatar');
                        nv.textContent = '';
                        nv.style.backgroundImage = 'url(' + me.profilePictureUrl + ')';
                        nv.style.backgroundSize = 'cover';
                        nv.style.backgroundPosition = 'center';
                    }
                }
            }
            
            document.getElementById('fee-form').onsubmit = async function(e) {
                e.preventDefault();
                var btn = document.getElementById('btn-update-fee');
                var alertBox = document.getElementById('fee-alert');
                btn.disabled = true;
                btn.textContent = 'Updating...';
                
                try {
                    var updateResp = await fetch('/api/doctors/fee', {
                        method: 'POST',
                        headers: { 
                            'Authorization': 'Bearer ' + token,
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            fee: parseFloat(document.getElementById('fee-amount').value),
                            currency: document.getElementById('fee-currency').value
                        })
                    });
                    var updateBody = await updateResp.json();
                    if (updateBody.success) {
                        alertBox.textContent = 'Fee updated successfully!';
                        alertBox.style.color = 'var(--forest-dark)';
                        alertBox.style.background = 'var(--sage-light)';
                    } else {
                        alertBox.textContent = updateBody.message || 'Failed to update fee.';
                        alertBox.style.color = 'var(--coral)';
                        alertBox.style.background = 'var(--coral-light)';
                    }
                    alertBox.style.display = 'inline-block';
                    setTimeout(() => { alertBox.style.display = 'none'; }, 3000);
                } catch(err) {
                    alertBox.textContent = 'Network error.';
                    alertBox.style.color = 'var(--coral)';
                    alertBox.style.background = 'var(--coral-light)';
                    alertBox.style.display = 'inline-block';
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Update Fee';
                }
            };
            
            var listEl = document.getElementById('doctor-appointments-list');
            
            if (body.success && body.data && body.data.items) {
                var patients = body.data.items;
                
                patients.forEach(function(p) {
                    p._dateObj = new Date(0);
                    if (p.appointmentDate) {
                        var d = new Date(p.appointmentDate);
                        if (p.appointmentTime) {
                            var parts = p.appointmentTime.split(':');
                            if (parts.length >= 2) {
                                d.setHours(parseInt(parts[0], 10));
                                d.setMinutes(parseInt(parts[1], 10));
                            }
                        }
                        p._dateObj = d;
                    }
                });
                
                patients.sort(function(a, b) {
                    return a._dateObj - b._dateObj;
                });
                
                if (patients.length === 0) {
                    listEl.innerHTML = '<div style="padding:40px; text-align:center; color:var(--muted);">No patients assigned to you yet.</div>';
                } else {
                    var html = '';
                    var now = new Date();
                    
                    var nextApptIndex = patients.findIndex(p => p.appointmentStatus !== 'Completed');
                    
                    patients.forEach(function(p, i) {
                        var isNext = i === nextApptIndex;
                        var time = p.appointmentTime || '--:--';
                        var date = p.appointmentDate ? new Date(p.appointmentDate).toLocaleDateString() : 'No date';
                        var isTimeStarted = now >= p._dateObj;
                        
                        var isCompleted = p.appointmentStatus === 'Completed';
                        var statusHtml = '';
                        if (isCompleted) {
                            statusHtml = '<span class="appt-status done">Done ✓</span>';
                        } else if (isTimeStarted) {
                            statusHtml = `<button class="appt-status action" onclick="completeAppointment('${p.id}')">Mark Done</button>`;
                        } else {
                            statusHtml = `<button class="appt-status action" disabled style="background:var(--muted); opacity:0.6; cursor:not-allowed;">Scheduled</button>`;
                        }
                        
                        html += `
                        <div class="appt-item">
                          <span class="appt-time ${isNext ? 'next' : ''}">${time}</span>
                          <span class="appt-bar ${isNext ? 'next' : ''}"></span>
                          <div class="appt-info"><div class="name">${p.name}</div><div class="date">${date}</div></div>
                          ${statusHtml}
                        </div>
                        `;
                    });
                    listEl.innerHTML = html;
                    
                    // Update stats
                    document.getElementById('stat-appt-num').textContent = patients.length;
                    document.getElementById('stat-pat-num').textContent = patients.length;
                    
                    if (nextApptIndex !== -1) {
                        var nt = patients[nextApptIndex].appointmentTime || '--:--';
                        document.getElementById('stat-next-time').textContent = nt;
                        document.getElementById('stat-next-name').textContent = patients[nextApptIndex].name;
                    } else {
                        document.getElementById('stat-next-time').textContent = '--:--';
                        document.getElementById('stat-next-name').textContent = 'None';
                    }
                }
            } else {
                listEl.innerHTML = '<div style="padding:40px; text-align:center; color:var(--coral);">Failed to load patients.</div>';
            }
        } catch (e) {
            document.getElementById('doctor-appointments-list').innerHTML = '<div style="padding:40px; text-align:center; color:var(--coral);">Network error.</div>';
        }
    });

    window.completeAppointment = async function(id) {
        if (!confirm('Mark this appointment as completed?')) return;
        try {
            var token = localStorage.getItem('hcrm_token');
            var resp = await fetch('/api/patients/' + id + '/complete', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            var body = await resp.json();
            if (body.success) {
                window.location.reload();
            } else {
                alert(body.message || 'Failed to complete appointment.');
            }
        } catch(e) {
            alert('Network error.');
        }
    }
</script>
</body>
</html>
