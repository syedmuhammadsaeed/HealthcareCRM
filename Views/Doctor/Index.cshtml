@{
    ViewData["Title"] = "Doctors";
}

@section Styles {
    <link rel="stylesheet" href="~/css/doctor.css" asp-append-version="true" />
}

<div class="page">
    <div class="page-head">
      <div>
        <h1>Doctors</h1>
        <p>Directory of active clinical staff</p>
      </div>
    </div>
    <div class="readonly-badge">Read-only — full management arrives in Week 3</div>

    <div class="stat-row">
      <div class="stat c1">
        <span class="icon">🩺</span>
        <div><div class="num" id="stat-total">0</div><div class="lbl">Total doctors</div></div>
      </div>
      <div class="stat c2">
        <span class="icon">🟢</span>
        <div><div class="num" id="stat-active">0</div><div class="lbl">Active</div></div>
      </div>
      <div class="stat c3">
        <span class="icon">⏸</span>
        <div><div class="num" id="stat-inactive">0</div><div class="lbl">Inactive</div></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-toolbar">
        <div class="search-box">🔍 <input id="search-input" placeholder="Search by name or specialization…" autocomplete="off" /></div>
        <div class="chip-filter" id="filter-chips">
          <button class="on" data-filter="all">All</button>
          <button data-filter="active">Active</button>
          <button data-filter="inactive">Inactive</button>
        </div>
      </div>

      <table class="dt">
        <thead>
          <tr>
            <th>Name</th>
            <th>Specialization</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="doctor-table-body">
          <tr>
            <td colspan="5" style="text-align:center; padding: 20px;">Loading doctors...</td>
          </tr>
        </tbody>
      </table>

      <div class="panel-footer">
        <div class="footer-info" id="footer-info">Showing doctors</div>

        <nav class="pagination" aria-label="Pagination" id="pagination-controls">
          <!-- Pagination rendered by JS -->
        </nav>
      </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/doctor.js" asp-append-version="true"></script>
}
