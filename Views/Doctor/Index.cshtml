              <input type="password" id="pwd-new" class="input-control" placeholder="Enter new password" oninput="checkPwdRules(this.value)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" onclick="togglePwd('pwd-new', this)"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
          </div>
          <div class="input-group full-width">
            <label class="form-label">Confirm New Password</label>
            <div class="input-with-icon">
              <input type="password" id="pwd-confirm" class="input-control" placeholder="Confirm new password">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" onclick="togglePwd('pwd-confirm', this)"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
          </div>
          <div class="password-rules">
            <div class="rules-header">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg> <strong>Password must contain:</strong>
            </div>
            <div class="rules-grid">
              <span id="rule-len" style="transition: all 0.2s;">✓ At least 8 characters</span>
              <span id="rule-num" style="transition: all 0.2s;">✓ One number</span>
              <span id="rule-up" style="transition: all 0.2s;">✓ One uppercase letter</span>
              <span id="rule-sp" style="transition: all 0.2s;">✓ One special character</span>
