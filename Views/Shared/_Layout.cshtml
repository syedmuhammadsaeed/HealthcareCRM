<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HealthcareCRM – Manage patients and clinical workflows efficiently." />
    <title>@ViewData["Title"] – HealthcareCRM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/patient.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool isAuthPage = ctrl.Equals("Account", StringComparison.OrdinalIgnoreCase);
}
<body class="@(isAuthPage ? "auth-page-body" : "")">

    <!-- ── App Layout ────────────────────────────────────────── -->
    @if (!isAuthPage)
    {
        <div class="app-container">
            <aside class="sidebar">
                <a href="/" class="brand" style="text-decoration: none; color: inherit; cursor: pointer;">
                    <div class="logo-icon"><i class="fa-solid fa-heart-pulse"></i></div>
                    <div class="brand-text">
                        <span class="brand-name">MediCare</span>
                        <span class="brand-tag">Better care. Every day.</span>
                    </div>
                </a>

                <nav class="nav-menu">
                    <a href="/Home" class="@(ctrl == "Home" ? "active" : "")"><i class="fa-solid fa-house"></i> Overview</a>
                    <a href="/Patient" class="@(ctrl == "Patient" ? "active" : "")"><i class="fa-regular fa-user"></i> Patients</a>
                    <a href="/Doctor" class="@(ctrl == "Doctor" ? "active" : "")"><i class="fa-solid fa-user-doctor"></i> Doctors</a>
                    <a href="/Appointment" class="@(ctrl == "Appointment" ? "active" : "")"><i class="fa-regular fa-calendar"></i> Appointments</a>
                    <a href="/Billing" class="@(ctrl == "Billing" ? "active" : "")"><i class="fa-solid fa-file-invoice"></i> Billings</a>
                    <a href="/Report" class="@(ctrl == "Report" ? "active" : "")"><i class="fa-regular fa-file-lines"></i> Reports</a>
                    <a href="/Settings" class="@(ctrl == "Settings" ? "active" : "")"><i class="fa-solid fa-gear"></i> Settings</a>
                </nav>

                <div class="sidebar-bottom">
                    <div class="user-profile-card" id="nav-authenticated" style="display:none;">
                        <div class="avatar" id="nav-user-avatar">..</div>
                        <div class="user-info">
                            <span class="name" id="nav-user-name">Loading...</span>
                            <span class="role">Administrator</span>
                        </div>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>

                    <a href="#" class="logout-link" id="nav-logout-btn" onclick="logout()" style="display:none;" title="Sign out">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
                    </a>

                    <!-- Guest State -->
                    <a href="/Account/Login" class="login-link" id="nav-guest" style="display:none;">
                        Sign In
                    </a>
                </div>
            </aside>
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
