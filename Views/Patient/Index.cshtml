@{
    ViewData["Title"] = "Patients";
}

<div class="page">
    <div class="page-head">
      <div>
        <h1>Patient roster</h1>
        <p id="page-info-text">Loading...</p>
      </div>
      <a href="/Patient/Create" class="btn-add">+ Add patient</a>
    </div>

    <div class="panel">
      <div class="panel-toolbar">
        <div class="search-box">🔍 <input id="search-input" class="pm-search-input" placeholder="Search by name, phone, or city…" autocomplete="off" /></div>
        <div class="chip-filter" id="filter-chips">
          <button class="pm-chip on" data-filter="all">All</button>
          <button class="pm-chip" data-filter="active">Active</button>
          <button class="pm-chip" data-filter="followup">Follow-up</button>
          <button class="pm-chip" data-filter="critical">Critical</button>
        </div>
      </div>

      <table class="pt">
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone Number</th>
            <th>Date of Birth</th>
            <th>Gender</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="patient-table-body">
          <tr><td colspan="5" style="text-align:center; padding: 20px;">Loading patients...</td></tr>
        </tbody>
      </table>

      <div class="panel-footer">
        <div class="footer-info" id="footer-info">Showing patients</div>

        <nav class="pagination" aria-label="Pagination" id="pagination-controls">
          <!-- Pagination rendered by JS -->
        </nav>

        <div class="per-page">
          <span>Rows per page</span>
          <select id="page-size-select">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
          </select>
        </div>
      </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/patient.js" asp-append-version="true"></script>
}
