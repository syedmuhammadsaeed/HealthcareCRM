@{
ViewData["Title"] = "Sign In";
}

@section Styles {
<link href="~/css/login.css" rel="stylesheet" asp-append-version="true" />
}

<main class="auth-wrap">
    <div class="auth-card">

        <div class="auth-eyebrow"><span class="icon">✛</span> Secure clinician access</div>

        <h1>Welcome back</h1>
        <p class="sub">Sign in to your HealthcareCRM account to manage patients, appointments, and records.</p>

        <div id="alert-container" role="alert" aria-live="polite"></div>

        <form id="login-form" novalidate>
            <div class="field">
                <label id="role-label">Login as</label>
                <div class="role-select" role="radiogroup" aria-labelledby="role-label">
                    <label class="role-pill selected">
                        <input type="radio" name="role" value="Admin" checked />
                        <span class="role-ic">🛡</span>
                        <span class="role-txt">Admin</span>
                    </label>
                    <label class="role-pill">
                        <input type="radio" name="role" value="SuperAdmin" />
                        <span class="role-ic">⭐</span>
                        <span class="role-txt">Super Admin</span>
                    </label>
                    <label class="role-pill">
                        <input type="radio" name="role" value="Doctor" />
                        <span class="role-ic">🩺</span>
                        <span class="role-txt">Doctor</span>
                    </label>
                </div>
            </div>

            <div class="field">
                <label for="email">Email address</label>
                <div class="input-shell">
                    <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="you@example.com"
                    autocomplete="email"
                    aria-invalid="false"
                    aria-describedby="email-error"
                    required
                    />
                </div>
                <span class="error-msg" id="email-error" role="alert">Please enter a valid email address.</span>
            </div>

            <div class="field">
                <div class="field-row" style="margin-bottom:-1px;">
                    <label for="password">Password</label>
                </div>
                <div class="input-shell">
                    <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Enter your password"
                    autocomplete="current-password"
                    aria-invalid="false"
                    aria-describedby="password-error"
                    required
                    />
                    <button type="button" class="toggle-pw" aria-label="Show password" aria-pressed="false">Show</button>
                </div>
                <span class="error-msg" id="password-error" role="alert">Password is required.</span>
            </div>

            <div class="field-row">
                <label class="remember">
                    <input type="checkbox" name="remember" />
                    Remember me
                </label>
                <a class="forgot-link" href="#">Forgot password?</a>
            </div>

            <button type="submit" class="btn-signin" id="login-btn">
                <span class="spinner" id="login-spinner" aria-hidden="true"></span>
                <span id="login-btn-text">Sign in</span>
            </button>

            <div class="divider">or</div>

            <button type="button" class="btn-alt">
                Sign in with hospital SSO
            </button>
        </form>

        <p class="footer-note">Don't have an account? <a href="/Account/Register">Create one</a></p>
    </div>
</main>

@section Scripts {
<script src="~/js/login.js" asp-append-version="true"></script>
}