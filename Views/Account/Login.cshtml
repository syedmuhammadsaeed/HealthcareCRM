@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-logo" aria-hidden="true">&#9877;&#65039;</span>
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to your HealthcareCRM account</p>
        </div>

        <div id="alert-container" role="alert" aria-live="polite"></div>

        <form id="login-form" novalidate>
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" class="form-control" id="email"
                       placeholder="you@example.com" autocomplete="email" required />
                <div class="invalid-feedback">Please enter a valid email address.</div>
            </div>
            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password"
                       placeholder="Enter your password" autocomplete="current-password" required />
                <div class="invalid-feedback">Password is required.</div>
            </div>
            <button type="submit" class="btn btn-primary btn-login w-100" id="login-btn">
                <span id="login-btn-text">Sign In</span>
                <span class="spinner-border spinner-border-sm ms-2 d-none"
                      id="login-spinner" role="status" aria-hidden="true"></span>
            </button>
        </form>

        <p class="auth-footer-text">
            Don't have an account?
            <a href="/Account/Register" class="auth-link" id="link-register">Create one</a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/js/login.js" asp-append-version="true"></script>
}
