@{
    ViewData["Title"] = "Create Account";
}

@section Styles {
    <link href="~/css/register.css" rel="stylesheet" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<main class="register-split-layout">
    <!-- Left Panel: Image -->
    <div class="register-left">
        <div class="register-image-container">
            <img src="/images/Signup.png" alt="Patients and Clinicians" class="register-bg-image" />
        </div>
    </div>

    <!-- Right Panel: Form -->
    <div class="register-right">
        <div class="register-form-container">
            <!-- Logo -->
            <a href="/" class="brand-logo" style="text-decoration: none; cursor: pointer;">
                <div class="brand-icon"><i class="fa-solid fa-plus"></i></div>
                <div class="brand-text">
                    <h2>MediCare</h2>
                    <span class="brand-sub">CAREER ASSISTANT</span>
                </div>
            </a>

            <h1>Create your account.</h1>
            <p class="sub">Free for academic use. No credit card.</p>

            <div id="alert-container" role="alert" aria-live="polite"></div>

            <form id="register-form" novalidate>
                <div class="field" style="display:none;">
                    <input type="hidden" name="role" id="role-user" value="User" />
                    <!-- Hidden full name to preserve JS compatibility if needed -->
                    <input type="hidden" id="fullName" name="fullName" value="Placeholder" />
                </div>

                <div class="name-row">
                    <div class="field">
                        <label for="firstName">First name</label>
                        <div class="input-shell">
                            <input type="text" id="firstName" name="firstName" autocomplete="given-name" required />
                        </div>
                    </div>
                    <div class="field">
                        <label for="lastName">Last name</label>
                        <div class="input-shell">
                            <input type="text" id="lastName" name="lastName" autocomplete="family-name" required />
                        </div>
                    </div>
                </div>

                <div class="field">
                    <label for="email"> email</label>
                    <div class="input-shell">
                        <input type="email" id="email" name="email" placeholder="admin@pt.com" autocomplete="email" required />
                    </div>
                    <span class="error-msg" id="email-error" role="alert">Please enter a valid email address.</span>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <div class="input-shell">
                        <input type="password" id="password" name="password" autocomplete="new-password" aria-describedby="pw-requirements" required />
                        <!-- Keeping the toggle but hidden if not needed, or just let CSS handle it -->
                        <button type="button" class="toggle-pw" aria-label="Show password"><i class="fa-regular fa-eye"></i></button>
                    </div>

                    <!-- Password strength meter from mockup -->
                    <div class="pw-strength-label">
                        <span>Password strength</span>
                        <span id="pw-strength-text">Too weak</span>
                    </div>
                    <div class="pw-meter" aria-hidden="true">
                        <div class="bar" data-bar="1"></div>
                        <div class="bar" data-bar="2"></div>
                        <div class="bar" data-bar="3"></div>
                        <div class="bar" data-bar="4"></div>
                    </div>
                    
                    <ul class="req-list" id="pw-requirements">
                        <li data-req="len"><span class="dot"></span> Min 8 characters</li>
                        <li data-req="upper"><span class="dot"></span> Uppercase letter</li>
                        <li data-req="lower"><span class="dot"></span> Lowercase letter</li>
                        <li data-req="num"><span class="dot"></span> Number</li>
                        <li data-req="special"><span class="dot"></span> Special character</li>
                    </ul>
                </div>

                <!-- Confirm password hidden by default as it's not in the new mockup -->
                <div class="field" style="display:none;">
                    <label for="confirm">Confirm password</label>
                    <div class="input-shell">
                        <input type="password" id="confirm" name="confirm" value="Placeholder1!" />
                    </div>
                </div>

                <label class="terms-label">
                    <div class="custom-checkbox">
                        <input type="checkbox" name="terms" id="terms" required checked />
                        <span class="checkmark"><i class="fa-solid fa-check"></i></span>
                    </div>
                    <span>I agree to the <strong>Terms</strong> and <strong>Privacy Policy</strong>.</span>
                </label>
                <span class="error-msg" id="terms-error" role="alert">You must agree to the terms.</span>

                <button type="submit" class="btn-signin" id="register-btn">
                    <span class="spinner" id="register-spinner"></span>
                    <span id="register-btn-text">Create Account</span>
                </button>
            </form>

            <p class="footer-note">Already have an account? <a href="/Account/Login">Sign in</a></p>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/register.js" asp-append-version="true"></script>
}
