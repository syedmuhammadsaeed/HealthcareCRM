@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services — MediCare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="brand-card">
            <div class="brand-icon">
                <i class="fa-solid fa-heart-pulse"></i>
            </div>
            <div class="brand-text">
                <h1>MediCare</h1>
                <p>Better care. Every day.</p>
            </div>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/Landing/Services" class="active">Services</a>
            <a href="/Landing/AboutUs">About Us</a>
            <a href="/Landing/Contact">Contact</a>
        </div>

        <div class="nav-actions">
            <a href="/Account/Login" class="btn-outline">Login</a>
            <a href="/Account/Register" class="btn-solid">Signup</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" style="min-height: 90vh; overflow: hidden; padding-top: 120px;">
        <!-- Layer 3: Outer fully blurred background -->
        <div class="services-hero-bg"></div>
        
        <!-- Layer 2: Inner clear image container -->
        <div class="services-hero-inner-bg"></div>
        
        <!-- Layer 1: Content -->
        <div style="width: 100%; display: flex; flex-direction: column; max-width: 1100px; margin: 0 auto; position: relative; z-index: 1;">
            
            <div class="services-header">
                <h2>A Full Spectrum of Healthcare Services.</h2>
                <p>From routine check-ups to specialized care, we offer comprehensive medical services designed around you.</p>
            </div>

            <!-- Top Grid -->
            <div class="services-grid-top">
                
                <div class="service-card">
                    <div class="service-icon-box">
                        <i class="fa-solid fa-stethoscope"></i>
                        <i class="fa-solid fa-microscope"></i>
                    </div>
                    <h3>Doctor Consultations</h3>
                    <h4>Primary and Specialized</h4>
                    <p>Expert consultations in primary care, pediatrics, and various specialties.</p>
                    <a href="/Account/Register">View Specialties &rarr;</a>
                </div>
                
                <div class="service-card">
                    <div class="service-icon-box">
                        <i class="fa-solid fa-x-ray"></i>
                        <i class="fa-solid fa-vial"></i>
                    </div>
                    <h3>Diagnostic Imaging & Labs</h3>
                    <h4>Online Reports</h4>
                    <p>Advanced imaging (MRI, CT) and complete laboratory services, with results available in your portal.</p>
                    <a href="/Account/Register">Schedule Tests &rarr;</a>
                </div>
                
                <div class="service-card">
                    <div class="service-icon-box">
                        <i class="fa-regular fa-calendar-check"></i>
                        <i class="fa-solid fa-video"></i>
                    </div>
                    <h3>Appointment Management</h3>
                    <h4>Virtual & In-Person</h4>
                    <p>Seamlessly schedule virtual and physical appointments with our integrated booking system.</p>
                    <a href="/Account/Register">Manage Appointments &rarr;</a>
                </div>
                
                <div class="service-card">
                    <div class="service-icon-box">
                        <i class="fa-solid fa-leaf"></i>
                        <i class="fa-solid fa-heart-pulse"></i>
                    </div>
                    <h3>Patient Wellness & Chronic Care</h3>
                    <h4>Patient Wellness</h4>
                    <p>Curated wellness programs, preventative screenings, and chronic condition management.</p>
                    <a href="/Account/Register">Explore Wellness &rarr;</a>
                </div>

            </div>

            <!-- Bottom Grid -->
            <div class="services-grid-bottom">
                
                <div class="service-bottom-card">
                    <h3>Specialized Care</h3>
                    <p>Choose from our specific departments.</p>
                    
                    <div class="specialized-grid">
                        <div class="specialized-pill"><i class="fa-solid fa-heart-circle-check"></i> Cardiology</div>
                        <div class="specialized-pill"><i class="fa-solid fa-ribbon"></i> Oncology</div>
                        <div class="specialized-pill"><i class="fa-solid fa-hand-dots"></i> Dermatology</div>
                        <div class="specialized-pill"><i class="fa-solid fa-person-pregnant"></i> Gynecology</div>
                        <div class="specialized-pill"><i class="fa-solid fa-brain"></i> Mental Health</div>
                        <div class="specialized-pill"><i class="fa-solid fa-scalpel"></i> Surgery</div>
                    </div>
                </div>

                <div class="service-bottom-card">
                    <h3>How it Works</h3>
                    <p>A new patient to access our services.</p>
                    
                    <div class="how-it-works-grid">
                        <div class="how-it-works-step">
                            <div class="step-number">1</div>
                            <h4>Register Account</h4>
                            <p>New patient creates your portal.</p>
                        </div>
                        <div class="how-it-works-step">
                            <div class="step-number">2</div>
                            <h4>Book Appointment</h4>
                            <p>Select specialized services.</p>
                        </div>
                        <div class="how-it-works-step">
                            <div class="step-number">3</div>
                            <h4>Consult Doctor</h4>
                            <p>See your medical care.</p>
                        </div>
                        <div class="how-it-works-step">
                            <div class="step-number">4</div>
                            <h4>Access Reports</h4>
                            <p>Access online services.</p>
                        </div>
                    </div>
                </div>

            </div>
            
        </div>
    </section>

    <!-- Comprehensive Footer -->
    <footer class="footer-comprehensive">
        <div class="footer-watermark">MediCare</div>
        
        <div class="footer-columns">
            <div class="footer-col">
                <h4>Patient Dashboard</h4>
                <p>lit patient dashboard and doctors circuit to spend your</p>
                <ul>
                    <li><a href="#">View Reports</a></li>
                    <li><a href="#">Track Vitals</a></li>
                    <li><a href="#">Book Appointment</a></li>
                    <li><a href="#">Patient Guide</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Doctor Portal</h4>
                <p>Book as your emouttiness and doctor portal</p>
                <ul>
                    <li><a href="#">Patient Overview</a></li>
                    <li><a href="#">Schedule</a></li>
                    <li><a href="#">Billing</a></li>
                    <li><a href="#">Doctor Resources</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/Landing/AboutUs">About Us</a></li>
                    <li><a href="/Landing/Contact">Contact Us</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Blog</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Resources</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Use</a></li>
                    <li><a href="#">Accessibility</a></li>
                    <li><a href="#">Security</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-left">
                <i class="fa-regular fa-heart"></i> MediCare &copy; 2026 MediCare. All rights reserved.
            </div>
            
            <div class="social-icons">
                <i class="fa-brands fa-facebook"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-youtube"></i>
                <i class="fa-brands fa-linkedin"></i>
            </div>
            
            <div class="footer-bottom-right">
                <a href="#">Site Map</a>
                <a href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">Back to Top</a>
            </div>
        </div>
    </footer>

</body>
</html>
