@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us — MediCare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="brand-card">
            <div class="brand-icon">
                <i class="fa-solid fa-heart-pulse"></i>
            </div>
            <div class="brand-text">
                <h1>MediCare</h1>
                <p>Better care. Every day.</p>
            </div>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/Landing/Services">Services</a>
            <a href="/Landing/AboutUs">About Us</a>
            <a href="/Landing/Contact" class="active">Contact</a>
        </div>

        <div class="nav-actions">
            <a href="/Account/Login" class="btn-outline">Login</a>
            <a href="/Account/Register" class="btn-solid">Signup</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" style="min-height: 90vh;">
        <div class="contact-hero-bg"></div>
        <div class="contact-hero-content">
            <div class="contact-left">
                <h2>Get in Touch</h2>
                
                <div class="contact-info-item">
                    <div class="contact-info-icon"><i class="fa-regular fa-envelope"></i></div>
                    <div class="contact-info-text">
                        <h4>Email</h4>
                        <p>Friendsware@gmail.com</p>
                        <span>We strive to respond to all emails within two working days.</span>
                    </div>
                </div>
                
                <div class="contact-info-item">
                    <div class="contact-info-icon"><i class="fa-solid fa-phone"></i></div>
                    <div class="contact-info-text">
                        <h4>Contact Number</h4>
                        <p>03355294136</p>
                    </div>
                </div>
                
                <div class="contact-info-item">
                    <div class="contact-info-icon"><i class="fa-brands fa-linkedin-in"></i></div>
                    <div class="contact-info-text">
                        <h4>LinkedIn</h4>
                        <p>Friendsware/linkedine.com</p>
                    </div>
                </div>
            </div>
            
            <div class="contact-right">
                <input type="text" class="form-control" placeholder="Name" />
                <input type="email" class="form-control" placeholder="Email Address" />
                <select class="form-control" style="appearance: auto;">
                    <option value="" disabled selected>Reason for Contact</option>
                    <option value="support">General Support</option>
                    <option value="billing">Billing Inquiry</option>
                    <option value="partnership">Partnership</option>
                </select>
                <textarea class="form-control" placeholder="Message"></textarea>
                <button type="button" class="contact-btn-submit" onclick="alert('Message sent successfully!')">Submit</button>
            </div>
        </div>
    </section>

    <!-- Comprehensive Footer -->
    <footer class="footer-comprehensive">
        <div class="footer-watermark">MediCare</div>
        
        <div class="footer-columns">
            <div class="footer-col">
                <h4>Patient Dashboard</h4>
                <p>lit patient dashboard and doctors circuit to spend your</p>
                <ul>
                    <li><a href="#">View Reports</a></li>
                    <li><a href="#">Track Vitals</a></li>
                    <li><a href="#">Book Appointment</a></li>
                    <li><a href="#">Patient Guide</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Doctor Portal</h4>
                <p>Book as your emouttiness and doctor portal</p>
                <ul>
                    <li><a href="#">Patient Overview</a></li>
                    <li><a href="#">Schedule</a></li>
                    <li><a href="#">Billing</a></li>
                    <li><a href="#">Doctor Resources</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="#">About Us</a></li>
                    <li><a href="/Landing/Contact">Contact Us</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Blog</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Resources</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Use</a></li>
                    <li><a href="#">Accessibility</a></li>
                    <li><a href="#">Security</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-left">
                <i class="fa-regular fa-heart"></i> MediCare &copy; 2026 MediCare. All rights reserved.
            </div>
            
            <div class="social-icons">
                <i class="fa-brands fa-facebook"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-youtube"></i>
                <i class="fa-brands fa-linkedin"></i>
            </div>
            
            <div class="footer-bottom-right">
                <a href="#">Site Map</a>
                <a href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">Back to Top</a>
            </div>
        </div>
    </footer>

</body>
</html>
