@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us — MediCare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="brand-card">
            <div class="brand-icon">
                <i class="fa-solid fa-heart-pulse"></i>
            </div>
            <div class="brand-text">
                <h1>MediCare</h1>
                <p>Better care. Every day.</p>
            </div>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/Landing/Services">Services</a>
            <a href="/Landing/AboutUs" class="active">About Us</a>
            <a href="/Landing/Contact">Contact</a>
        </div>

        <div class="nav-actions">
            <a href="/Account/Login" class="btn-outline">Login</a>
            <a href="/Account/Register" class="btn-solid">Signup</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" style="min-height: 90vh; overflow: hidden;">
        <!-- Layer 3: Outer fully blurred background -->
        <div class="about-hero-bg"></div>
        
        <!-- Layer 2: Inner clear image container -->
        <div class="about-hero-inner-bg"></div>
        
        <!-- Layer 1: Glass Cards -->
        <div style="width: 100%; display: flex; flex-direction: column; gap: 24px; max-width: 1100px; margin: 0 auto; padding: 40px 0; position: relative; z-index: 1;">
            
            <!-- Top Row -->
            <div class="about-hero-content" style="padding: 0;">
                <div class="about-card">
                    <h2>About MediCare: Our<br/>Mission & Vision</h2>
                    <p>We are committed to providing accessible,<br/>personalized healthcare through a seamless digital<br/>experience. Our mission is to make healthcare simple<br/>and human-centric for everyone.</p>
                </div>
                
                <div class="about-card transparent">
                    <div class="about-features-grid">
                        <div class="about-feature-box">
                            <div class="about-feature-icon"><i class="fa-solid fa-users"></i></div>
                            <h4>Our Community</h4>
                            <p>Building relationships between patients and providers.</p>
                        </div>
                        <div class="about-feature-box">
                            <div class="about-feature-icon"><i class="fa-solid fa-network-wired"></i></div>
                            <h4>Efficiency</h4>
                            <p>Streamlining appointments and records for better care.</p>
                        </div>
                        <div class="about-feature-box">
                            <div class="about-feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
                            <h4>Integrity</h4>
                            <p>Data security and care excellence you can trust.</p>
                        </div>
                        <div class="about-feature-box">
                            <div class="about-feature-icon"><i class="fa-solid fa-stethoscope"></i></div>
                            <h4>Innovation</h4>
                            <p>Leveraging technology for better health outcomes.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom Row -->
            <div class="about-hero-content row-2" style="padding: 0;">
                <div class="about-card">
                    <h2>The MediCare<br/>Approach</h2>
                    <p>An integrated platform built with patients and doctors in mind, ensuring clarity at every step of your health journey.</p>
                </div>
                
                <div class="about-card">
                    <h2>Meet Our Medical Leadership</h2>
                    <div class="about-leadership-grid">
                        <!-- Leader 1 -->
                        <div class="about-leader-item">
                            <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=2070&auto=format&fit=crop" alt="Dr. Alice Chen" class="about-leader-img" />
                            <div class="about-leader-text">
                                <h4>Dr. Alice Chen</h4>
                                <p>Chief Medical Officer</p>
                                <span>15+ years of clinical excellence</span>
                            </div>
                        </div>
                        <!-- Leader 2 -->
                        <div class="about-leader-item">
                            <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070&auto=format&fit=crop" alt="Dr. Robert Smith" class="about-leader-img" />
                            <div class="about-leader-text">
                                <h4>Dr. Robert Smith</h4>
                                <p>Chief Medical Officer</p>
                                <span>15+ years of clinical excellence</span>
                            </div>
                        </div>
                        <!-- Leader 3 -->
                        <div class="about-leader-item">
                            <img src="https://images.unsplash.com/photo-1537368910025-700350fe46c7?q=80&w=2070&auto=format&fit=crop" alt="Dr. James Wilson" class="about-leader-img" />
                            <div class="about-leader-text">
                                <h4>Dr. James Wilson</h4>
                                <p>Chief Medical Officer</p>
                                <span>15+ years of clinical excellence</span>
                            </div>
                        </div>
                        <!-- Leader 4 -->
                        <div class="about-leader-item">
                            <img src="https://images.unsplash.com/photo-1594824436951-7f1269556d44?q=80&w=2070&auto=format&fit=crop" alt="Dr. Aley Lora" class="about-leader-img" />
                            <div class="about-leader-text">
                                <h4>Dr. Aley Lora</h4>
                                <p>Chief Medical Officer</p>
                                <span>15+ years of clinical excellence</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </section>

    <!-- Comprehensive Footer -->
    <footer class="footer-comprehensive">
        <div class="footer-watermark">MediCare</div>
        
        <div class="footer-columns">
            <div class="footer-col">
                <h4>Patient Dashboard</h4>
                <p>lit patient dashboard and doctors circuit to spend your</p>
                <ul>
                    <li><a href="#">View Reports</a></li>
                    <li><a href="#">Track Vitals</a></li>
                    <li><a href="#">Book Appointment</a></li>
                    <li><a href="#">Patient Guide</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Doctor Portal</h4>
                <p>Book as your emouttiness and doctor portal</p>
                <ul>
                    <li><a href="#">Patient Overview</a></li>
                    <li><a href="#">Schedule</a></li>
                    <li><a href="#">Billing</a></li>
                    <li><a href="#">Doctor Resources</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/Landing/AboutUs">About Us</a></li>
                    <li><a href="/Landing/Contact">Contact Us</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Blog</a></li>
                </ul>
            </div>
            
            <div class="footer-col">
                <h4>Resources</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Use</a></li>
                    <li><a href="#">Accessibility</a></li>
                    <li><a href="#">Security</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-left">
                <i class="fa-regular fa-heart"></i> MediCare &copy; 2026 MediCare. All rights reserved.
            </div>
            
            <div class="social-icons">
                <i class="fa-brands fa-facebook"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-youtube"></i>
                <i class="fa-brands fa-linkedin"></i>
            </div>
            
            <div class="footer-bottom-right">
                <a href="#">Site Map</a>
                <a href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">Back to Top</a>
            </div>
        </div>
    </footer>

</body>
</html>
